rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userRole() {
      return signedIn() && exists(userDocPath()) ? get(userDocPath()).data.role : null;
    }

    function isAdmin() {
      return userRole() == "admin";
    }

    function isManager() {
      return userRole() == "manager";
    }

    function canWriteCmsContent() {
      return ["admin", "writer", "manager"].hasAny([userRole()]);
    }

    function isSystemCollection(collectionId) {
      return ["users", "views", "cmsSchemas"].hasAny([collectionId]);
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow create, update, delete: if canWriteCmsContent();
    }

    match /views/{viewId} {
      allow read: if true;
      allow create, update, delete: if canWriteCmsContent();
    }

    match /cmsSchemas/{schemaId} {
      allow read: if signedIn();
      allow create, update, delete: if isManager() || isAdmin();
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == null;
      allow update: if isAdmin()
        || (signedIn()
          && request.auth.uid == userId
          && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // Colecciones de contenido dinámico definidas desde cmsSchemas.
    match /{collectionId}/{docId} {
      allow read: if signedIn() && !isSystemCollection(collectionId);
      allow create, update, delete: if canWriteCmsContent() && !isSystemCollection(collectionId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
